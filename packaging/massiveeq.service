[Unit]
Description=MassiveEQ systemwide playback equalizer
Documentation=https://github.com/massiveeq/massiveeq
After=pipewire.service wireplumber.service
Wants=pipewire.service wireplumber.service

[Service]
Type=dbus
BusName=org.massiveeq.Service1
ExecStart=/usr/bin/massiveeqd
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target

