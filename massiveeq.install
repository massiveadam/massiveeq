post_install() {
  printf '%s\n' \
    'MassiveEQ is installed.' \
    'Launch MassiveEQ from the application menu, or enable its login service with:' \
    '  systemctl --user enable --now massiveeq.service'
}

post_upgrade() {
  post_install
}

post_remove() {
  printf '%s\n' \
    'If the user service is still loaded, disable it with:' \
    '  systemctl --user disable --now massiveeq.service'
}
